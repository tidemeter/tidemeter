# ===========================================
# TideMeter Configuration
# ===========================================

# --- Database (PayloadCMS) ---
# Supports: postgresql, sqlite, mongodb
DATABASE_URL=postgresql://tidemeter:tidemeter@localhost:5480/tidemeter
PAYLOAD_SECRET=change-me-to-a-random-secret-at-least-32-chars

# --- Analytics Database ---
# Type: postgresql (default) | clickhouse | sqlite
ANALYTICS_DB_TYPE=postgresql
ANALYTICS_DATABASE_URL=postgresql://tidemeter:tidemeter@localhost:5480/tidemeter

# ClickHouse (only if ANALYTICS_DB_TYPE=clickhouse)
# CLICKHOUSE_URL=http://localhost:8124
# CLICKHOUSE_DATABASE=tidemeter_analytics
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# SQLite (only if ANALYTICS_DB_TYPE=sqlite)
# ANALYTICS_SQLITE_PATH=./data/analytics.db

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3700
NODE_ENV=development

# --- Schema migrations (advanced) ---
# Force PayloadCMS schema-sync mode regardless of NODE_ENV.
# Default: push mode in dev, versioned migrations in production.
# Set "true" for one boot when upgrading a deployment whose schema was
# originally created in push mode (no payload_migrations rows yet), then
# unset to return to migrations.
# PAYLOAD_DB_PUSH=true

# --- Session Hashing ---
# Secret used for hashing visitor IDs (rotated daily for privacy)
SESSION_SALT_SECRET=change-me-to-a-random-secret

# --- GeoIP (optional) ---
# Download MaxMind GeoLite2-City.mmdb with `pnpm geoip:download`, or let the Docker image download it on startup.
# GEOIP_DB_PATH=./data/GeoLite2-City.mmdb
# MAXMIND_ACCOUNT_ID=
# MAXMIND_LICENSE_KEY=
# Optional direct .mmdb or .tar.gz source, useful for mirrors or pre-hosted databases.
# GEO_DATABASE_URL=

# --- Demo Mode (optional) ---
# Set to "true" to seed demo user (demo@demo.com / demodemo) and sample analytics data on startup
# DEMO_MODE=true

# --- Email (optional) ---
# TideMeter only uses email for password reset / account verification.
# Skip this block entirely for single-user / private deployments — Payload
# will log a one-time warning and write any outgoing email to stdout, but
# /admin, /admin/create-first-user and /admin/account all work without email.
#
# Two backends are supported, picked in this order:
#
#   1. RESEND_API_KEY  → uses Resend (HTTP API, no SMTP needed)
#   2. SMTP_HOST       → uses Nodemailer SMTP (works with any provider)
#
# --- Option 1: Resend (https://resend.com) ---
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
#
# --- Option 2: SMTP (Postfix, Gmail, SendGrid, Mailgun, Postmark, SES, …) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_SECURE=false           # true for implicit TLS (port 465); auto-detected from port if unset
#
# Provider-specific notes for SMTP_USER:
#   - SendGrid: SMTP_USER must be the literal string "apikey" and
#     SMTP_PASSWORD is your SendGrid API key.
#   - Mailgun:  SMTP_USER is "postmaster@<your-domain>".
#   - AWS SES:  SMTP_USER is the SES SMTP username (not your AWS access key).
#   - Gmail:    SMTP_USER is the full Gmail address; SMTP_PASSWORD must be an
#               app password, not your account password.
#
# --- Shared "From" header (applies to both backends) ---
# SMTP_FROM_ADDRESS=no-reply@your-domain.com
# SMTP_FROM_NAME=TideMeter
