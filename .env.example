# ===========================================
# TideMeter Configuration
# ===========================================

# --- Database (PayloadCMS) ---
# Supports: postgresql, sqlite, mongodb
DATABASE_URL=postgresql://tidemeter:tidemeter@localhost:5480/tidemeter
PAYLOAD_SECRET=change-me-to-a-random-secret-at-least-32-chars

# --- Analytics Database ---
# Type: postgresql (default) | clickhouse | sqlite
ANALYTICS_DB_TYPE=postgresql
ANALYTICS_DATABASE_URL=postgresql://tidemeter:tidemeter@localhost:5480/tidemeter

# ClickHouse (only if ANALYTICS_DB_TYPE=clickhouse)
# CLICKHOUSE_URL=http://localhost:8124
# CLICKHOUSE_DATABASE=tidemeter_analytics
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# SQLite (only if ANALYTICS_DB_TYPE=sqlite)
# ANALYTICS_SQLITE_PATH=./data/analytics.db

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3700
NODE_ENV=development

# --- Session Hashing ---
# Secret used for hashing visitor IDs (rotated daily for privacy)
SESSION_SALT_SECRET=change-me-to-a-random-secret

# --- GeoIP (optional) ---
# Download MaxMind GeoLite2-City.mmdb and set path
# GEOIP_DB_PATH=./data/GeoLite2-City.mmdb

# --- Demo Mode (optional) ---
# Set to "true" to seed demo user (demo@demo.com / demodemo) and sample analytics data on startup
# DEMO_MODE=true
